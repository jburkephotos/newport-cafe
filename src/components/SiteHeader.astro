---
import { Image } from 'astro:assets';
import logo from '../assets/brand/logo.png';
import { site } from '../data/site.js';
---

<header class="site-header">
  <div class="container site-header__row">
    <a href="/" class="site-header__logo" aria-label={`${site.legalName} home`}>
      <Image src={logo} alt={site.legalName} height={88} densities={[1, 2]} loading="eager" />
    </a>
    <nav aria-label="Primary">
      <a href="/">Home</a>
      <a href="/menu">Menu</a>
      <a href={site.phoneHref} class="btn btn--call">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.6 15.6 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1A17 17 0 0 1 3 4c0-.6.4-1 1-1h3.4c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1l-2.1 2.2z"/></svg>
        <span class="site-header__calltext">{site.phoneDisplay}</span>
      </a>
    </nav>
  </div>
</header>
