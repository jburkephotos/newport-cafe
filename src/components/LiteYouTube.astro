---
// Load-on-click YouTube facade — zero network cost until the visitor clicks.
// Pass a videoId to go live; leave it empty to render a clearly-labeled
// placeholder slot (Jeremy drops the URL in later).
//
//   <LiteYouTube title="Monster Burger Challenge" id="dQw4w9WgXcQ" />
//   <LiteYouTube title="Coming soon" />            ← placeholder
const { id = '', title = 'Video', label = title } = Astro.props;
const thumb = id ? `https://i.ytimg.com/vi/${id}/hqdefault.jpg` : '';
---

{id ? (
  <button
    class="video-facade"
    style={`background-image:url('${thumb}')`}
    data-yt={id}
    aria-label={`Play video: ${title}`}
  >
    <span class="video-facade__play" aria-hidden="true"><span></span></span>
    <span class="video-facade__label">{label}</span>
  </button>
) : (
  <div class="video-placeholder" role="note">
    <div>
      <strong>▶ Video slot: {label}</strong><br />
      <small>Add a YouTube URL in <code>src/data/videos.js</code> to go live.</small>
    </div>
  </div>
)}

<script>
  // Swap facade → real iframe on click (autoplay because it's a user gesture).
  document.querySelectorAll('.video-facade').forEach((el) => {
    el.addEventListener('click', () => {
      const id = el.getAttribute('data-yt');
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = el.getAttribute('aria-label') || 'YouTube video';
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      el.replaceChildren(iframe);
    });
  });
</script>
